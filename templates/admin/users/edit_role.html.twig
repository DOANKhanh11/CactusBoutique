{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.edit_roles'|trans }} — {{ user.pseudo }}{% endblock %}

{% block body %}
<div class="section-header">
    <h1>🔑 {{ 'admin_dash.edit_title'|trans }} {{ user.pseudo }}</h1>
    <a href="{{ path('admin_users') }}" class="btn btn-secondary">← {{ 'common.back'|trans }}</a>
</div>

<div style="max-width:480px;background:var(--bg-secondary);border-radius:12px;padding:2rem;box-shadow:0 1px 3px var(--shadow-light);">
    <p style="color:var(--text-secondary);margin-top:0;">
        {{ user.prenom }} {{ user.nom }} &mdash; <code>{{ user.pseudo }}</code>
    </p>

    {{ form_start(form) }}
        <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:1.5rem;">
            {{ form_widget(form.roles) }}
        </div>
        <button type="submit" class="btn btn-primary">{{ 'admin_dash.save'|trans }}</button>
    {{ form_end(form) }}
</div>

{% block stylesheets %}
{{ parent() }}
<style>
    .form-check { display:flex; align-items:center; gap:8px; }
    .form-check input[type=checkbox] { width:16px; height:16px; cursor:pointer; }
    .form-check label { cursor:pointer; color:var(--text-primary); font-size:0.9rem; }
</style>
{% endblock %}
{% endblock %}
