{% extends 'base.html.twig' %}

{% block title %}{{ terreau.name }}{% endblock %}

{% block body %}
<div class="section-header">
    <h1>🌱 {{ terreau.name }}</h1>
    <a href="{{ path('app_terreau_index') }}" class="btn btn-secondary">← {{ 'terreau.back'|trans }}</a>
</div>

<div style="max-width:540px;background:var(--bg-secondary);border-radius:14px;padding:2rem;box-shadow:0 1px 3px var(--shadow-light);">
    <table class="data-table" style="margin-bottom:1.5rem;">
        <tbody>
            <tr><td><strong>{{ 'terreau.composition'|trans }}</strong></td><td>{{ terreau.composition }}</td></tr>
            <tr><td><strong>{{ 'terreau.price'|trans }}</strong></td><td><span class="badge badge-green">{{ terreau.prix }} €</span></td></tr>
        </tbody>
    </table>

    {% if is_granted('ROLE_ADMIN') %}
    <div class="action-btns">
        <a href="{{ path('app_terreau_edit', {id: terreau.id}) }}" class="btn btn-primary">✏️ {{ 'common.edit'|trans }}</a>
        {{ include('terreau/_delete_form.html.twig') }}
    </div>
    {% endif %}
</div>
{% endblock %}
