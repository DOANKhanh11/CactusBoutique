{% extends 'base.html.twig' %}

{% block title %}Terreau{% endblock %}

{% block body %}
    <div class="section-header">
        <h1>🌱 Terreau</h1>
    </div>

    <table class="data-table">
      <thead>
            <tr>
                <th>#</th>
                <th>Nom</th>
                <th>Composition</th>
                <th>Prix</th>
            </tr>
        </thead>
        <tbody>
             <tr>
                <td style="color: #ccc; font-size: 0.8rem">{{ terreau.id }}</td>
                <td><strong>{{ terreau.name }}</strong></td>
                <td style="color: #7a7a6e">{{ terreau.composition }}</td>
                <td><span class="badge badge-green">{{ terreau.prix }} €</span></td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_terreau_index') }}" class="btn btn-secondary">Back to list</a>

    <a href="{{ path('app_terreau_edit', {'id': terreau.id}) }}" class="btn btn-primary">Edit</a>

    {{ include('terreau/_delete_form.html.twig') }}
{% endblock %}
