{% extends 'base.html.twig' %}

{% block title %}Terreau{% endblock %}

{% block body %}
    <h1>Terreau</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ terreau.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ terreau.name }}</td>
            </tr>
            <tr>
                <th>Composition</th>
                <td>{{ terreau.composition }}</td>
            </tr>
            <tr>
                <th>Prix</th>
                <td>{{ terreau.prix }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_terreau_index') }}">back to list</a>

    <a href="{{ path('app_terreau_edit', {'id': terreau.id}) }}">edit</a>

    {{ include('terreau/_delete_form.html.twig') }}
{% endblock %}
