{% extends 'base.html.twig' %}

{% block title %}Terreau index{% endblock %}

{% block body %}
    <h1>Terreau index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Composition</th>
                <th>Prix</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for terreau in terreaus %}
            <tr>
                <td>{{ terreau.id }}</td>
                <td>{{ terreau.name }}</td>
                <td>{{ terreau.composition }}</td>
                <td>{{ terreau.prix }}</td>
                <td>
                    <a href="{{ path('app_terreau_show', {'id': terreau.id}) }}">show</a>
                    <a href="{{ path('app_terreau_edit', {'id': terreau.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_terreau_new') }}">Create new</a>
{% endblock %}
