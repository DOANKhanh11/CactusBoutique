{% extends 'base.html.twig' %}

{% block title %}{{ 'terreau.title'|trans }}{% endblock %}

{% block body %}
    <div class="section-header">
        <h1>🌱 {{ 'terreau.title'|trans }}</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_terreau_new') }}" class="btn btn-primary">+ {{ 'common.new'|trans }}</a>
        {% endif %}
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>{{ 'common.id'|trans }}</th>
                <th>{{ 'terreau.name'|trans }}</th>
                <th>{{ 'terreau.composition'|trans }}</th>
                <th>{{ 'terreau.price'|trans }}</th>
                <th>{{ 'common.actions'|trans }}</th>
            </tr>
        </thead>
        <tbody>
        {% for terreau in terreaus %}
            <tr>
                <td style="color: #ccc; font-size: 0.8rem">{{ terreau.id }}</td>
                <td><strong>{{ terreau.name }}</strong></td>
                <td style="color: #7a7a6e">{{ terreau.composition }}</td>
                <td><span class="badge badge-green">{{ terreau.prix }} €</span></td>
                <td>
                    <div class="action-btns">
                        <a href="{{ path('app_terreau_show', {'id': terreau.id}) }}" class="action-link">{{ 'common.see'|trans }}</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_terreau_edit', {'id': terreau.id}) }}" class="action-link">{{ 'common.edit'|trans }}</a>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr class="empty-row">
                <td colspan="5">—</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
