{% extends 'base.html.twig' %}

{% block title %}Terreau{% endblock %}

{% block body %}
    <div class="section-header">
        <h1>🌱 Terreau</h1>
        <a href="{{ path('app_terreau_new') }}" class="btn btn-primary">+ Nouveau</a>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Nom</th>
                <th>Composition</th>
                <th>Prix</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for terreau in terreaus %}
            <tr>
                <td style="color: #ccc; font-size: 0.8rem">{{ terreau.id }}</td>
                <td><strong>{{ terreau.name }}</strong></td>
                <td style="color: #7a7a6e">{{ terreau.composition }}</td>
                <td><span class="badge badge-green">{{ terreau.prix }} €</span></td>
                <td>
                    <div class="action-btns">
                        <a href="{{ path('app_terreau_show', {'id': terreau.id}) }}" class="action-link">Voir</a>
                        <a href="{{ path('app_terreau_edit', {'id': terreau.id}) }}" class="action-link">Modifier</a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr class="empty-row">
                <td colspan="5">Aucun substrat enregistré.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}