{% extends 'base.html.twig' %}

{% block title %}Cactus{% endblock %}

{% block body %}
    <h1>Cactus</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ cactu.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ cactu.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ cactu.description }}</td>
            </tr>
            <tr>
                <th>Prix</th>
                <td>{{ cactu.prix }}</td>
            </tr>
            <tr>
                <th>NiveauSoin</th>
                <td>{{ cactu.niveauSoin }}</td>
            </tr>
            <tr>
                <th>Arrosage</th>
                <td>{{ cactu.arrosage }}</td>
            </tr>
            <tr>
                <th>Taille</th>
                <td>{{ cactu.taille }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_cactus_index') }}">back to list</a>

    <a href="{{ path('app_cactus_edit', {'id': cactu.id}) }}">edit</a>

    {{ include('cactus/_delete_form.html.twig') }}
{% endblock %}
