{% extends 'base.html.twig' %}

{% block title %}Cactus — Boutique{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .search-panel {
        background: var(--bg-secondary);
        border-radius: 14px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 1px 3px var(--shadow-light);
    }
    .search-panel h2 {
        margin: 0 0 1rem;
        font-size: 1rem;
        font-weight: 700;
        color: var(--heading-color);
    }
    .search-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 0.75rem;
        align-items: end;
    }
    .search-grid label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 4px;
    }
    .search-grid input,
    .search-grid select {
        width: 100%;
        padding: 8px 10px;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        background: var(--bg-primary);
        color: var(--text-primary);
        font-size: 0.875rem;
        outline: none;
        transition: border-color 0.2s;
    }
    .search-grid input:focus,
    .search-grid select:focus {
        border-color: var(--link-color);
    }
    .search-actions {
        display: flex;
        gap: 0.5rem;
        align-items: flex-end;
    }
    .cactus-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.25rem;
    }
    .cactus-card {
        background: var(--bg-secondary);
        border-radius: 14px;
        padding: 1.25rem;
        box-shadow: 0 1px 3px var(--shadow-light);
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: transform 0.15s, box-shadow 0.15s;
    }
    .cactus-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px var(--shadow-medium);
    }
    .cactus-card h3 {
        margin: 0;
        font-size: 1rem;
        color: var(--heading-color);
    }
    .cactus-card .price {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--link-color);
    }
    .cactus-card .meta {
        font-size: 0.8rem;
        color: var(--text-secondary);
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .cactus-card .meta span {
        background: var(--bg-tertiary);
        padding: 2px 8px;
        border-radius: 999px;
    }
    .cactus-card .card-footer {
        margin-top: auto;
        padding-top: 0.75rem;
        border-top: 1px solid var(--border-color);
        display: flex;
        gap: 8px;
    }
    .results-count {
        font-size: 0.85rem;
        color: var(--text-secondary);
        margin-bottom: 1rem;
    }
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-secondary);
    }
    .empty-state .icon { font-size: 3rem; margin-bottom: 0.5rem; }
</style>
{% endblock %}

{% block body %}
<div class="section-header">
    <h1>🌵 Catalogue de cactus</h1>
    {% if is_granted('ROLE_USER') %}
        <a href="{{ path('app_cactus_new') }}" class="btn btn-primary">+ Publier une annonce</a>
    {% endif %}
</div>

{# ── Search panel ── #}
<div class="search-panel">
    <h2>🔍 Recherche avancée</h2>
    {{ form_start(searchForm, {attr: {novalidate: 'novalidate'}}) }}
    <div class="search-grid">
        <div>
            {{ form_label(searchForm.nom) }}
            {{ form_widget(searchForm.nom) }}
        </div>
        <div>
            {{ form_label(searchForm.categorie) }}
            {{ form_widget(searchForm.categorie) }}
        </div>
        <div>
            {{ form_label(searchForm.niveauSoin) }}
            {{ form_widget(searchForm.niveauSoin) }}
        </div>
        <div>
            {{ form_label(searchForm.prixMin) }}
            {{ form_widget(searchForm.prixMin) }}
        </div>
        <div>
            {{ form_label(searchForm.prixMax) }}
            {{ form_widget(searchForm.prixMax) }}
        </div>
        <div>
            {{ form_label(searchForm.expirationAvant) }}
            {{ form_widget(searchForm.expirationAvant) }}
        </div>
        <div>
            {{ form_label(searchForm.tri) }}
            {{ form_widget(searchForm.tri) }}
        </div>
        <div class="search-actions">
            <button type="submit" class="btn btn-primary" style="width:100%;">Rechercher</button>
            <a href="{{ path('app_cactus_index') }}" class="btn btn-secondary">Réinitialiser</a>
        </div>
    </div>
    {{ form_end(searchForm) }}
</div>

{# ── Results ── #}
<p class="results-count">{{ cacti|length }} résultat{{ cacti|length != 1 ? 's' : '' }} trouvé{{ cacti|length != 1 ? 's' : '' }}</p>

{% if cacti is empty %}
    <div class="empty-state">
        <div class="icon">🔎</div>
        <p>Aucun cactus ne correspond à votre recherche.</p>
        <a href="{{ path('app_cactus_index') }}" class="btn btn-secondary">Voir tous les cactus</a>
    </div>
{% else %}
    <div class="cactus-grid">
        {% for cactu in cacti %}
        <div class="cactus-card">
            <h3>{{ cactu.name }}</h3>
            <div class="price">{{ cactu.prix|number_format(2, ',', ' ') }} €</div>
            <p style="margin:0;font-size:0.85rem;color:var(--text-secondary);">{{ cactu.description|slice(0, 80) }}{% if cactu.description|length > 80 %}…{% endif %}</p>
            <div class="meta">
                {% if cactu.categorie %}
                    <span>📁 {{ cactu.categorie.name }}</span>
                {% endif %}
                <span>💧 {{ cactu.arrosage }}</span>
                <span>🌿 {{ cactu.niveauSoin }}</span>
                <span>📏 {{ cactu.taille }} cm</span>
                {% if cactu.dateExpiration %}
                    <span>⏳ {{ cactu.dateExpiration|date('d/m/Y') }}</span>
                {% endif %}
            </div>
            {% if cactu.vendeur %}
                <div style="font-size:0.8rem;color:var(--text-tertiary);">Vendu par <strong>{{ cactu.vendeur.pseudo }}</strong></div>
            {% endif %}
            <div class="card-footer">
                <a href="{{ path('app_cactus_show', {id: cactu.id}) }}" class="btn btn-primary" style="flex:1;justify-content:center;">Voir</a>
                {% if is_granted('ROLE_USER') and app.user == cactu.vendeur %}
                    <a href="{{ path('app_cactus_edit', {id: cactu.id}) }}" class="btn btn-secondary">Modifier</a>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
