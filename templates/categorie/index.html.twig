{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}
    <div class="section-header">
        <h1>📂 Catégories</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_categorie_new') }}" class="btn btn-primary">+ Nouveau</a>
        {% endif %}
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Nom</th>
                <th>Description</th>
                <th>Environnement</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for categorie in categories %}
            <tr>
                <td style="color: #ccc; font-size: 0.8rem">{{ categorie.id }}</td>
                <td><strong>{{ categorie.name }}</strong></td>
                <td style="color: #7a7a6e">{{ categorie.description }}</td>
                <td><span class="badge badge-sand">{{ categorie.environnement }}</span></td>
                <td>
                    <div class="action-btns">
                        <a href="{{ path('app_categorie_show', {'id': categorie.id}) }}" class="action-link">Voir</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="action-link">Modifier</a>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr class="empty-row">
                <td colspan="5">Aucune catégorie enregistrée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}