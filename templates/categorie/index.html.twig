{% extends 'base.html.twig' %}

{% block title %}{{ 'categorie.title'|trans }}{% endblock %}

{% block body %}
    <div class="section-header">
        <h1>📂 {{ 'categorie.title'|trans }}</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_categorie_new') }}" class="btn btn-primary">+ {{ 'common.new'|trans }}</a>
        {% endif %}
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>{{ 'common.id'|trans }}</th>
                <th>{{ 'categorie.name'|trans }}</th>
                <th>{{ 'categorie.description'|trans }}</th>
                <th>{{ 'categorie.environnement'|trans }}</th>
                <th>{{ 'common.actions'|trans }}</th>
            </tr>
        </thead>
        <tbody>
        {% for categorie in categories %}
            <tr>
                <td style="color: #ccc; font-size: 0.8rem">{{ categorie.id }}</td>
                <td><strong>{{ categorie.name }}</strong></td>
                <td style="color: #7a7a6e">{{ categorie.description }}</td>
                <td><span class="badge badge-sand">{{ categorie.environnement }}</span></td>
                <td>
                    <div class="action-btns">
                        <a href="{{ path('app_categorie_show', {'id': categorie.id}) }}" class="action-link">{{ 'common.see'|trans }}</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="action-link">{{ 'common.edit'|trans }}</a>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr class="empty-row">
                <td colspan="5">—</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
