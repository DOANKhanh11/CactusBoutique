{% extends 'base.html.twig' %}

{% block title %}Categorie{% endblock %}

{% block body %}
    <div class="section-header">
        <h1>📂 Catégories</h1>
    </div>

    <table class="data-table">
           <thead>
            <tr>
                <th>#</th>
                <th>Nom</th>
                <th>Description</th>
                <th>Environnement</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td style="color: #ccc; font-size: 0.8rem">{{ categorie.id }}</td>
                <td><strong>{{ categorie.name }}</strong></td>
                <td style="color: #7a7a6e">{{ categorie.description }}</td>
                <td><span class="badge badge-sand">{{ categorie.environnement }}</span></td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_categorie_index') }}" class="btn btn-secondary">Back to list</a>

    <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="btn btn-primary">Edit</a>

    {{ include('categorie/_delete_form.html.twig') }}
{% endblock %}
