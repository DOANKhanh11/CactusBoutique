<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Cactus Boutique{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

        {% block stylesheets %}
        <style>
            /* ── CSS Variables for Theming ── */
            :root[data-theme="light"],
            :root:not([data-theme]) {
                --bg-primary: #f7f5f0;
                --bg-secondary: #fff;
                --bg-tertiary: #f0ede6;
                --text-primary: #333;
                --text-secondary: #7a7a6e;
                --text-tertiary: #6b6b5e;
                --border-color: #f2f0ea;
                --menu-bg: #2f4f2f;
                --menu-text: rgba(255,255,255,0.8);
                --heading-color: #2f4f2f;
                --link-color: #5a8a5a;
                --shadow-light: rgba(0,0,0,0.06);
                --shadow-medium: rgba(47,79,47,0.2);
                --card-bg: rgba(255,255,255,0.6);
                --card-border: rgba(255,255,255,0.8);
                --hero-bg: linear-gradient(135deg, #f5f1e8 0%, #e8e4d8 100%);
                --transition-speed: 0.3s;
            }

            :root[data-theme="dark"] {
                --bg-primary: #1a1a1a;
                --bg-secondary: #2d2d2d;
                --bg-tertiary: #3a3a3a;
                --text-primary: #e0e0e0;
                --text-secondary: #b0b0b0;
                --text-tertiary: #a0a0a0;
                --border-color: #404040;
                --menu-bg: #1a1a1a;
                --menu-text: rgba(255,255,255,0.9);
                --heading-color: #e0e0e0;
                --link-color: #7fb069;
                --shadow-light: rgba(0,0,0,0.3);
                --shadow-medium: rgba(0,0,0,0.5);
                --card-bg: rgba(45,45,45,0.8);
                --card-border: rgba(100,100,100,0.5);
                --hero-bg: linear-gradient(135deg, #2d2d2d 0%, #1a1a1a 100%);
                --transition-speed: 0.3s;
            }

            /* ── Reset ── */
            *, *::before, *::after { box-sizing: border-box; }

            body {
                margin: 0;
                font-family: 'Segoe UI', Arial, sans-serif;
                background: var(--bg-primary);
                color: var(--text-primary);
                transition: background var(--transition-speed) ease, color var(--transition-speed) ease;
            }

            /* ── Navigation ── */
            .main-menu {
                background: var(--menu-bg);
                padding: 0 1.5rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                height: 56px;
                box-shadow: 0 1px 4px var(--shadow-light);
                transition: background var(--transition-speed) ease;
                flex-wrap: wrap;
            }

            .main-menu .brand {
                color: #fff;
                font-weight: 700;
                font-size: 1.05rem;
                text-decoration: none;
                letter-spacing: -0.01em;
                display: flex;
                align-items: center;
                gap: 8px;
                order: -1;
            }

            .main-menu > ul {
                margin: 0; padding: 0;
                list-style: none;
                display: flex;
                gap: 0.25rem;
            }

            .main-menu > ul:last-child {
                display: flex;
                gap: 0.5rem;
                align-items: center;
                margin-left: auto;
            }

            .main-menu a, .main-menu ul {
                color: var(--menu-text);
                text-decoration: none;
                font-size: 0.875rem;
                font-weight: 500;
                padding: 6px 12px;
                border-radius: 6px;
                transition: background var(--transition-speed), color var(--transition-speed);
            }

            .main-menu a {
                display: block;
            }

            .main-menu a:hover {
                background: rgba(255,255,255,0.12);
                color: #fff;
            }

            /* ── Page wrapper ── */
            .page-content {
                max-width: 1000px;
                margin: 0 auto;
                padding: 2rem 1.5rem;
            }

            /* ── Section header ── */
            .section-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 1.75rem;
            }

            .section-header h1 {
                margin: 0;
                font-size: 1.3rem;
                font-weight: 700;
                color: var(--heading-color);
                display: flex;
                align-items: center;
                gap: 8px;
            }

            /* ── Buttons ── */
            .btn {
                padding: 8px 18px;
                border-radius: 8px;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.85rem;
                transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
                display: inline-flex;
                align-items: center;
                gap: 6px;
                border: none;
                cursor: pointer;
            }

            .btn-primary {
                background: var(--heading-color);
                color: var(--bg-primary);
                box-shadow: 0 2px 8px var(--shadow-medium);
            }

            .btn-primary:hover {
                background: var(--link-color);
                transform: translateY(-1px);
                box-shadow: 0 4px 12px var(--shadow-medium);
            }

            .btn-secondary {
                background: var(--bg-secondary);
                color: var(--heading-color);
                border: 1px solid var(--border-color);
            }

            .btn-secondary:hover {
                background: var(--bg-tertiary);
                transform: translateY(-1px);
            }

            /* ── Table ── */
            .data-table {
                width: 100%;
                border-collapse: collapse;
                font-size: 0.875rem;
                background: var(--bg-secondary);
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0 1px 3px var(--shadow-light), 0 0 0 1px var(--shadow-light);
                transition: background var(--transition-speed);
            }

            .data-table thead tr {
                background: var(--bg-tertiary);
            }

            .data-table th {
                padding: 11px 16px;
                text-align: left;
                font-weight: 600;
                color: var(--text-secondary);
                font-size: 0.73rem;
                text-transform: uppercase;
                letter-spacing: 0.06em;
            }

            .data-table td {
                padding: 13px 16px;
                border-top: 1px solid var(--border-color);
                color: var(--text-primary);
                vertical-align: middle;
            }

            .data-table tbody tr:hover td {
                background: var(--bg-tertiary);
                transition: background var(--transition-speed);
            }

            .data-table th:last-child,
            .data-table td:last-child {
                text-align: right;
            }

            .data-table .empty-row td {
                text-align: center;
                color: var(--text-secondary);
                padding: 3rem;
                font-style: italic;
                font-size: 0.85rem;
            }

            /* ── Badges ── */
            .badge {
                display: inline-block;
                padding: 3px 10px;
                border-radius: 999px;
                font-size: 0.78rem;
                font-weight: 600;
            }

            .badge-green {
                background: #e6f4e6;
                color: #2a6b2a;
            }

            :root[data-theme="dark"] .badge-green {
                background: #1a3a1a;
                color: #7fb069;
            }

            .badge-sand {
                background: #f5f0e8;
                color: #7a6030;
            }

            :root[data-theme="dark"] .badge-sand {
                background: #3a2f1a;
                color: #e0c08a;
            }

            /* ── Action links ── */
            .action-btns {
                display: flex;
                gap: 10px;
                justify-content: flex-end;
            }

            .action-link {
                font-size: 0.8rem;
                color: var(--link-color);
                text-decoration: none;
                font-weight: 500;
                transition: color 0.15s;
            }

            .action-link:hover {
                color: var(--heading-color);
                text-decoration: underline;
            }

            .action-link.danger {
                color: #b85c5c;
            }

            :root[data-theme="dark"] .action-link.danger {
                color: #ff8888;
            }

            .action-link.danger:hover {
                color: #8b2e2e;
            }

            :root[data-theme="dark"] .action-link.danger:hover {
                color: #ffaa00;
            }

            /* ── Hero ── */
            .hero {
                min-height: calc(100vh - 56px);
                display: flex;
                align-items: center;
                justify-content: center;
                background:
                    radial-gradient(circle at 20% 30%, rgba(143,188,143,0.25), transparent 50%),
                    radial-gradient(circle at 80% 70%, rgba(244,196,168,0.3), transparent 50%),
                    var(--hero-bg);
                padding: 2rem;
                margin: -2rem -1.5rem;
                transition: background var(--transition-speed);
            }

            .hero-content {
                max-width: 900px;
                text-align: center;
                animation: fadeUp 0.9s ease-out;
            }

            .hero-emoji {
                font-size: 4.5rem;
                display: inline-block;
                animation: sway 4s ease-in-out infinite;
                filter: drop-shadow(0 6px 12px var(--shadow-medium));
            }

            .hero h1 {
                font-size: clamp(2.2rem, 5vw, 3.8rem);
                font-weight: 700;
                color: var(--heading-color);
                margin: 1rem 0 0.5rem;
                letter-spacing: -0.02em;
                line-height: 1.1;
            }

            .hero h1 .accent {
                background: linear-gradient(135deg, #5a8a5a, #7fb069);
                -webkit-background-clip: text;
                background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .hero .tagline {
                font-size: 1.1rem;
                color: var(--text-tertiary);
                max-width: 580px;
                margin: 1rem auto 2.5rem;
                line-height: 1.65;
            }

            .cta-group {
                display: flex;
                gap: 1rem;
                justify-content: center;
                flex-wrap: wrap;
                margin-bottom: 3.5rem;
            }

            .cta-group .btn {
                padding: 0.85rem 1.8rem;
                border-radius: 999px;
                font-size: 0.95rem;
            }

            .feature-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                gap: 1rem;
                max-width: 800px;
                margin: 0 auto;
            }

            .feature-card {
                background: var(--card-bg);
                backdrop-filter: blur(10px);
                border: 1px solid var(--card-border);
                border-radius: 16px;
                padding: 1.4rem 1rem;
                transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
                text-decoration: none;
                color: inherit;
            }

            .feature-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 10px 28px var(--shadow-medium);
                background: var(--bg-secondary);
            }

            .feature-icon {
                font-size: 1.9rem;
                margin-bottom: 0.5rem;
                display: block;
            }

            .feature-card h3 {
                margin: 0.2rem 0 0.15rem;
                color: var(--heading-color);
                font-size: 1rem;
            }

            .feature-card p {
                margin: 0;
                color: var(--text-secondary);
                font-size: 0.82rem;
            }

            /* ── Theme Switcher ── */
            .theme-switcher {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: var(--bg-secondary);
                border: 1px solid var(--border-color);
                border-radius: 999px;
                padding: 4px 8px;
            }

            .theme-switcher button {
                background: none;
                border: none;
                cursor: pointer;
                padding: 6px 10px;
                border-radius: 6px;
                transition: background var(--transition-speed);
                font-size: 1.1rem;
            }

            .theme-switcher button.active {
                background: var(--heading-color);
                color: var(--bg-primary);
            }

            .theme-switcher button:hover:not(.active) {
                background: var(--bg-tertiary);
            }

            /* ── Animations ── */
            @keyframes fadeUp {
                from { opacity: 0; transform: translateY(20px); }
                to   { opacity: 1; transform: translateY(0); }
            }

            @keyframes sway {
                0%, 100% { transform: rotate(-3deg); }
                50%       { transform: rotate(3deg); }
            }
        </style>
        {% endblock %}

        {% block javascripts %}
        <script>
            // Apply theme: server preference takes priority over localStorage
            (function() {
                const themeKey = 'cactus_boutique_theme';
                const serverTheme = '{{ user_theme() }}';
                // Server preference always wins (set to 'light' for guests)
                const theme = serverTheme;

                document.documentElement.setAttribute('data-theme', theme);
                localStorage.setItem(themeKey, theme);
            })();

            // Toggle theme and persist to server + localStorage
            function toggleTheme(newTheme = null) {
                const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
                const theme = newTheme || (currentTheme === 'light' ? 'dark' : 'light');

                document.documentElement.setAttribute('data-theme', theme);
                localStorage.setItem('cactus_boutique_theme', theme);

                fetch('/preferences/api/theme/' + theme, { method: 'POST' })
                    .catch(() => {});

                return theme;
            }

            // Make it globally available
            window.toggleTheme = toggleTheme;
        </script>
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
            <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
            <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
            <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {{ include('menu/home.html.twig') }}
        <div class="page-content">
            {% block body %}{% endblock %}
        </div>
    </body>
</html>