{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.login_title'|trans }}{% endblock %}

{% block body %}
    <h1>{{ 'auth.login_title'|trans }}</h1>

    {% if error %}
        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form action="{{ path('app_login') }}" method="post">
        <div>
            <label for="pseudo">{{ 'auth.pseudo'|trans }}</label>
            <input type="text" id="pseudo" name="pseudo" value="{{ last_username }}" required autofocus>
        </div>
        <div>
            <label for="password">{{ 'auth.password'|trans }}</label>
            <input type="password" id="password" name="password" required>
        </div>
        <button type="submit">{{ 'auth.submit_login'|trans }}</button>
    </form>

    <p>
        <a href="{{ path('app_register') }}">{{ 'auth.no_account'|trans }}</a>
    </p>
{% endblock %}
