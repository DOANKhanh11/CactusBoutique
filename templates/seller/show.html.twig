{% extends 'base.html.twig' %}

{% block title %}{{ 'seller.title'|trans }} — {{ seller.pseudo }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .stars { display:flex; gap:4px; }
    .star { font-size:1.6rem; cursor:pointer; color:#ccc; transition:color 0.1s; }
    .star.filled, .star.hover { color:#f4a800; }
    .comment-card {
        background:var(--bg-secondary);
        border-radius:10px;
        padding:1rem 1.25rem;
        border:1px solid var(--border-color);
        margin-bottom:0.75rem;
    }
    .comment-meta { font-size:0.8rem; color:var(--text-secondary); margin-bottom:0.4rem; }
    .comment-body { font-size:0.9rem; color:var(--text-primary); }
</style>
{% endblock %}

{% block body %}
<div class="section-header">
    <h1>👤 {{ seller.prenom }} {{ seller.nom }}
        <span style="color:var(--text-secondary);font-size:1rem;">({{ seller.pseudo }})</span>
    </h1>
    <a href="{{ path('app_cactus_index') }}" class="btn btn-secondary">← {{ 'cactus.back'|trans }}</a>
</div>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div style="padding:10px 16px;border-radius:8px;margin-bottom:1rem;background:{% if label=='success' %}#e6f4e6{% else %}#fdecea{% endif %};color:{% if label=='success' %}#2a6b2a{% else %}#8b2e2e{% endif %};">
            {{ message|trans }}
        </div>
    {% endfor %}
{% endfor %}

<div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start;">

{# ── Left: rating + comment form ── #}
<div>
    <div style="background:var(--bg-secondary);border-radius:14px;padding:1.5rem;margin-bottom:1.5rem;box-shadow:0 1px 3px var(--shadow-light);">
        <h2 style="margin:0 0 1rem;font-size:1rem;color:var(--heading-color);">⭐ {{ 'seller.rating'|trans }}</h2>
        <div style="font-size:2rem;font-weight:800;color:var(--heading-color);display:flex;align-items:center;gap:8px;">
            {{ avgRating > 0 ? avgRating : '—' }}
            <span style="color:#f4a800;">★</span>
        </div>
        <p style="margin:0.25rem 0 0;font-size:0.85rem;color:var(--text-secondary);">
            {{ 'seller.based_on'|trans }} {{ ratingCount }} {{ ratingCount != 1 ? ('seller.notes'|trans) : ('seller.note'|trans) }}
        </p>

        {% if is_granted('ROLE_USER') and app.user != seller %}
        <form method="post" action="{{ path('app_seller_show', {id: seller.id}) }}" style="margin-top:1.25rem;">
            <p style="font-size:0.85rem;color:var(--text-secondary);margin:0 0 6px;">
                {{ 'seller.your_rating'|trans }} {% if currentUserRating %}({{ currentUserRating.score }}★){% endif %} :
            </p>
            <div class="stars" id="star-rating">
                {% for i in 1..5 %}
                    <span class="star {% if currentUserRating and currentUserRating.score >= i %}filled{% endif %}"
                          data-value="{{ i }}">★</span>
                {% endfor %}
            </div>
            <input type="hidden" name="score" id="score-input" value="{{ currentUserRating ? currentUserRating.score : '' }}">
            <button type="submit" class="btn btn-primary" style="margin-top:0.75rem;font-size:0.85rem;">{{ 'seller.save_rating'|trans }}</button>
        </form>
        {% elseif not is_granted('ROLE_USER') %}
        <p style="font-size:0.85rem;color:var(--text-secondary);margin-top:1rem;">
            {{ 'seller.login_to_rate'|trans }}
        </p>
        {% endif %}
    </div>

    {% if commentForm %}
    <div style="background:var(--bg-secondary);border-radius:14px;padding:1.5rem;box-shadow:0 1px 3px var(--shadow-light);">
        <h2 style="margin:0 0 1rem;font-size:1rem;color:var(--heading-color);">💬 {{ 'seller.comment_title'|trans }}</h2>
        {{ form_start(commentForm) }}
            <div style="margin-bottom:0.75rem;">
                {{ form_widget(commentForm.contenu, {attr: {style: 'width:100%;padding:8px;border-radius:8px;border:1px solid var(--border-color);background:var(--bg-primary);color:var(--text-primary);font-size:0.875rem;resize:vertical;'}}) }}
                {% if form_errors(commentForm.contenu) %}
                    <p style="color:#b85c5c;font-size:0.8rem;margin:4px 0 0;">{{ form_errors(commentForm.contenu) }}</p>
                {% endif %}
            </div>
            <button type="submit" class="btn btn-primary">{{ 'seller.comment_publish'|trans }}</button>
        {{ form_end(commentForm) }}
    </div>
    {% elseif not is_granted('ROLE_USER') %}
    <p style="font-size:0.85rem;color:var(--text-secondary);">
        {{ 'seller.login_to_comment'|trans }}
    </p>
    {% endif %}
</div>

{# ── Right: comments list ── #}
<div>
    <h2 style="font-size:1rem;color:var(--heading-color);margin:0 0 1rem;">💬 {{ 'seller.comments'|trans }} ({{ comments|length }})</h2>
    {% for comment in comments %}
    <div class="comment-card">
        <div class="comment-meta">
            <strong>{{ comment.auteur.pseudo }}</strong> · {{ comment.dateCree|date('d/m/Y') }}
            {% if is_granted('ROLE_USER') and (app.user == comment.auteur or is_granted('ROLE_ADMIN')) %}
            <form method="post" action="{{ path('app_seller_comment_delete', {id: seller.id, commentId: comment.id}) }}" style="display:inline;margin-left:8px;">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_comment_' ~ comment.id) }}">
                <button type="submit" style="background:none;border:none;cursor:pointer;color:#b85c5c;font-size:0.78rem;"
                        onclick="return confirm('{{ 'seller.delete_comment_confirm'|trans }}')">{{ 'seller.delete_comment'|trans }}</button>
            </form>
            {% endif %}
        </div>
        <div class="comment-body">{{ comment.contenu }}</div>
    </div>
    {% else %}
    <p style="color:var(--text-secondary);font-style:italic;font-size:0.875rem;">{{ 'seller.no_comments'|trans }}</p>
    {% endfor %}
</div>

</div>

<script>
    const stars = document.querySelectorAll('#star-rating .star');
    const input = document.getElementById('score-input');
    if (stars.length && input) {
        stars.forEach(star => {
            star.addEventListener('mouseenter', () => {
                const val = +star.dataset.value;
                stars.forEach(s => s.classList.toggle('hover', +s.dataset.value <= val));
            });
            star.addEventListener('mouseleave', () => stars.forEach(s => s.classList.remove('hover')));
            star.addEventListener('click', () => {
                const val = +star.dataset.value;
                input.value = val;
                stars.forEach(s => s.classList.toggle('filled', +s.dataset.value <= val));
            });
        });
    }
</script>
{% endblock %}
