{% extends "base.html.twig" %}

{% block title %}{{ 'preferences.title'|trans }} — Cactus Boutique{% endblock %}

{% block body %}
<div class="section-header">
    <h1>⚙️ {{ 'preferences.title'|trans }}</h1>
    <a href="{{ path('app_home') }}" class="btn btn-secondary">← {{ 'common.back'|trans }}</a>
</div>

{% for message in app.flashes('success') %}
    <div style="padding:12px 16px;background:#e6f4e6;color:#2a6b2a;border-radius:8px;margin-bottom:1rem;">✓ {{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div style="padding:12px 16px;background:#f5e6e6;color:#6b2a2a;border-radius:8px;margin-bottom:1rem;">✗ {{ message }}</div>
{% endfor %}

<div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(300px, 1fr));gap:2rem;margin-top:2rem;">

    <div style="padding:2rem;border-radius:12px;border:1px solid var(--border-color);background:var(--bg-secondary);">
        <h2 style="margin-top:0;color:var(--heading-color);">🎨 {{ 'preferences.theme'|trans }}</h2>
        <p style="color:var(--text-secondary);margin-bottom:1.5rem;">{{ 'preferences.theme_desc'|trans }}</p>
        <div style="display:flex;gap:1rem;">
            <form method="POST" action="{{ path('app_theme_set', {theme: 'light'}) }}" style="flex:1;">
                <button type="submit" class="btn btn-{{ theme == 'light' ? 'primary' : 'secondary' }}" style="width:100%;justify-content:center;">
                    ☀️ {{ 'preferences.light'|trans }}
                </button>
            </form>
            <form method="POST" action="{{ path('app_theme_set', {theme: 'dark'}) }}" style="flex:1;">
                <button type="submit" class="btn btn-{{ theme == 'dark' ? 'primary' : 'secondary' }}" style="width:100%;justify-content:center;">
                    🌙 {{ 'preferences.dark'|trans }}
                </button>
            </form>
        </div>
        <p style="font-size:0.85rem;color:var(--text-secondary);margin-top:1rem;">
            {{ 'preferences.current_theme'|trans }}: <strong>{{ theme == 'dark' ? ('preferences.dark'|trans) : ('preferences.light'|trans) }}</strong>
        </p>
    </div>

    <div style="padding:2rem;border-radius:12px;border:1px solid var(--border-color);background:var(--bg-secondary);">
        <h2 style="margin-top:0;color:var(--heading-color);">🌍 {{ 'preferences.language'|trans }}</h2>
        <p style="color:var(--text-secondary);margin-bottom:1.5rem;">{{ 'preferences.language_desc'|trans }}</p>
        <div style="display:flex;gap:1rem;">
            <form method="POST" action="{{ path('app_preferences_language', {language: 'fr'}) }}" style="flex:1;">
                <button type="submit" class="btn btn-{{ language == 'fr' ? 'primary' : 'secondary' }}" style="width:100%;justify-content:center;">
                    🇫🇷 Français
                </button>
            </form>
            <form method="POST" action="{{ path('app_preferences_language', {language: 'en'}) }}" style="flex:1;">
                <button type="submit" class="btn btn-{{ language == 'en' ? 'primary' : 'secondary' }}" style="width:100%;justify-content:center;">
                    🇬🇧 English
                </button>
            </form>
        </div>
        <p style="font-size:0.85rem;color:var(--text-secondary);margin-top:1rem;">
            {{ 'preferences.current_language'|trans }}: <strong>{{ language == 'en' ? 'English' : 'Français' }}</strong>
        </p>
    </div>

</div>
{% endblock %}
