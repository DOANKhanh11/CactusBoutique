{% extends 'base.html.twig' %}

{% block title %}{{ 'commande.my_orders'|trans }}{% endblock %}

{% block body %}
<div class="section-header">
    <h1>📦 {{ 'commande.my_orders'|trans }}</h1>
    <a href="{{ path('app_cactus_index') }}" class="btn btn-secondary">← {{ 'commande.catalog'|trans }}</a>
</div>

<table class="data-table">
    <thead>
        <tr>
            <th>{{ 'common.id'|trans }}</th>
            <th>{{ 'commande.date'|trans }}</th>
            <th>{{ 'commande.status'|trans }}</th>
            <th>{{ 'commande.total'|trans }}</th>
            <th>{{ 'common.actions'|trans }}</th>
        </tr>
    </thead>
    <tbody>
    {% for commande in commandes %}
        <tr>
            <td style="color:var(--text-secondary);font-size:0.8rem;">{{ commande.id }}</td>
            <td>{{ commande.dateCree ? commande.dateCree|date('d/m/Y') : '—' }}</td>
            <td><span class="badge badge-green">{{ commande.status }}</span></td>
            <td><strong>{{ commande.prixTotal|number_format(2, ',', ' ') }} €</strong></td>
            <td>
                <a href="{{ path('app_commande_show', {id: commande.id}) }}" class="action-link">{{ 'common.see'|trans }}</a>
            </td>
        </tr>
    {% else %}
        <tr class="empty-row"><td colspan="5">{{ 'commande.no_orders'|trans }}</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
