{% extends 'base.html.twig' %}

{% block title %}{{ 'pot.title'|trans }}{% endblock %}

{% block body %}
<div class="section-header">
    <h1>🪴 {{ 'pot.title'|trans }}</h1>
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_pot_new') }}" class="btn btn-primary">+ {{ 'common.new'|trans }}</a>
    {% endif %}
</div>

<table class="data-table">
    <thead>
        <tr>
            <th>{{ 'common.id'|trans }}</th>
            <th>{{ 'pot.name'|trans }}</th>
            <th>{{ 'pot.material'|trans }}</th>
            <th>{{ 'pot.couleur'|trans }}</th>
            <th>{{ 'pot.price'|trans }}</th>
            <th>{{ 'common.actions'|trans }}</th>
        </tr>
    </thead>
    <tbody>
    {% for pot in pots %}
        <tr>
            <td style="color:#ccc;font-size:0.8rem">{{ pot.id }}</td>
            <td><strong>{{ pot.name }}</strong></td>
            <td>{{ pot.material }}</td>
            <td>{{ pot.couleur }}</td>
            <td><span class="badge badge-green">{{ pot.prix }} €</span></td>
            <td>
                <div class="action-btns">
                    <a href="{{ path('app_pot_show', {id: pot.id}) }}" class="action-link">{{ 'common.see'|trans }}</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_pot_edit', {id: pot.id}) }}" class="action-link">{{ 'common.edit'|trans }}</a>
                    {% endif %}
                </div>
            </td>
        </tr>
    {% else %}
        <tr class="empty-row"><td colspan="6">—</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
