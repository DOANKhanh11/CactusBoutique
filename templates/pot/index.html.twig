{% extends 'base.html.twig' %}

{% block title %}Pots{% endblock %}

{% block body %}
<div class="section-header">
    <h1>🪴 Pots</h1>
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_pot_new') }}" class="btn btn-primary">+ Nouveau</a>
    {% endif %}
</div>

<table class="data-table">
    <thead>
        <tr>
            <th>#</th>
            <th>Nom</th>
            <th>Matériau</th>
            <th>Couleur</th>
            <th>Prix</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for pot in pots %}
        <tr>
            <td style="color:#ccc;font-size:0.8rem">{{ pot.id }}</td>
            <td><strong>{{ pot.name }}</strong></td>
            <td>{{ pot.material }}</td>
            <td>{{ pot.couleur }}</td>
            <td><span class="badge badge-green">{{ pot.prix }} €</span></td>
            <td>
                <div class="action-btns">
                    <a href="{{ path('app_pot_show', {id: pot.id}) }}" class="action-link">Voir</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_pot_edit', {id: pot.id}) }}" class="action-link">Modifier</a>
                    {% endif %}
                </div>
            </td>
        </tr>
    {% else %}
        <tr class="empty-row"><td colspan="6">Aucun pot enregistré.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
