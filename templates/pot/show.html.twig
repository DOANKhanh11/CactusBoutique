{% extends 'base.html.twig' %}

{% block title %}Pot{% endblock %}

{% block body %}
    <h1>Pot</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ pot.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ pot.name }}</td>
            </tr>
            <tr>
                <th>Material</th>
                <td>{{ pot.material }}</td>
            </tr>
            <tr>
                <th>Couleur</th>
                <td>{{ pot.couleur }}</td>
            </tr>
            <tr>
                <th>Prix</th>
                <td>{{ pot.prix }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_pot_index') }}">back to list</a>

    <a href="{{ path('app_pot_edit', {'id': pot.id}) }}">edit</a>

    {{ include('pot/_delete_form.html.twig') }}
{% endblock %}
