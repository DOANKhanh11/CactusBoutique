{% extends 'base.html.twig' %}

{% block title %}{{ 'profile.title'|trans }}{% endblock %}

{% block body %}
    <section class="section-header">
        <div>
            <h1>{{ 'profile.title'|trans }}</h1>
            <p>{{ 'profile.welcome'|trans }} {{ user.pseudo }}.</p>
        </div>
    </section>

    <section class="card" style="margin-bottom: 2rem; padding: 1.5rem; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 18px;">
        <h2>{{ 'auth.pseudo'|trans }}</h2>
        <p><strong>{{ 'auth.nom'|trans }} :</strong> {{ user.nom }} {{ user.prenom }}</p>
        <p><strong>{{ 'profile.pseudo'|trans }} :</strong> {{ user.pseudo }}</p>
        <p><strong>{{ 'profile.roles'|trans }} :</strong> {{ user.roles|join(', ') }}</p>

        <form method="post" action="{{ path('app_profile_delete') }}"
              onsubmit="return confirm('{{ 'profile.delete_confirm'|trans }}')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
            <button type="submit" class="btn" style="background:#b85c5c;color:#fff;margin-top:0.5rem;">
                🗑️ {{ 'profile.delete_account'|trans }}
            </button>
        </form>
    </section>

    <section style="margin-bottom: 2rem;">
        <div class="section-header">
            <h2>{{ 'profile.favorites'|trans }}</h2>
            <a href="{{ path('app_cactus_index') }}" class="btn btn-secondary">{{ 'cactus.title'|trans }}</a>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>{{ 'cactus.name'|trans }}</th>
                    <th>{{ 'cactus.category'|trans }}</th>
                    <th>{{ 'cactus.price'|trans }}</th>
                    <th>{{ 'cactus.seller'|trans }}</th>
                    <th>{{ 'cactus.expiry'|trans }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for cactu in favorites %}
                    <tr>
                        <td>{{ cactu.name }}</td>
                        <td>{{ cactu.categorie.name }}</td>
                        <td>{{ cactu.prix }} €</td>
                        <td>{{ cactu.vendeur.pseudo }}</td>
                        <td>{{ cactu.dateExpiration ? cactu.dateExpiration|date('Y-m-d') : ('cactus.no_expiry'|trans) }}</td>
                        <td><a href="{{ path('app_cactus_show', {'id': cactu.id}) }}" class="action-link">{{ 'common.see'|trans }}</a></td>
                    </tr>
                {% else %}
                    <tr class="empty-row"><td colspan="6">{{ 'profile.no_favorites'|trans }}</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    <section style="margin-bottom: 2rem;">
        <div class="section-header">
            <h2>{{ 'profile.orders'|trans }}</h2>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>{{ 'common.id'|trans }}</th>
                    <th>{{ 'commande.date'|trans }}</th>
                    <th>{{ 'commande.status'|trans }}</th>
                    <th>{{ 'commande.total'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for commande in orders %}
                    <tr>
                        <td>{{ commande.id }}</td>
                        <td>{{ commande.dateCree ? commande.dateCree|date('Y-m-d') : '—' }}</td>
                        <td>{{ commande.status }}</td>
                        <td>{{ commande.prixTotal }} €</td>
                    </tr>
                {% else %}
                    <tr class="empty-row"><td colspan="4">{{ 'profile.no_orders'|trans }}</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    <section>
        <div class="section-header">
            <h2>{{ 'profile.listings'|trans }}</h2>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>{{ 'cactus.name'|trans }}</th>
                    <th>{{ 'cactus.price'|trans }}</th>
                    <th>{{ 'cactus.category'|trans }}</th>
                    <th>{{ 'commande.status'|trans }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for cactu in annonces %}
                    <tr>
                        <td>{{ cactu.name }}</td>
                        <td>{{ cactu.prix }} €</td>
                        <td>{{ cactu.categorie.name }}</td>
                        <td>{{ cactu.dateExpiration and cactu.dateExpiration > "now" ? 'Active' : 'Expirée' }}</td>
                        <td><a href="{{ path('app_cactus_show', {'id': cactu.id}) }}" class="action-link">{{ 'common.see'|trans }}</a></td>
                    </tr>
                {% else %}
                    <tr class="empty-row"><td colspan="5">{{ 'profile.no_listings'|trans }}</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
