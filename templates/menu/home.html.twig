<nav class="main-menu">
    <a href="{{ path('app_home') }}" class="brand">🌵 Cactus Boutique</a>
    <ul>
        <li><a href="{{ path('app_home') }}">{{ 'nav.home'|trans }}</a></li>
        <li><a href="{{ path('app_cactus_index') }}">{{ 'nav.cactus'|trans }}</a></li>
        <li><a href="{{ path('app_pot_index') }}">{{ 'nav.pot'|trans }}</a></li>
        <li><a href="{{ path('app_categorie_index') }}">{{ 'nav.categorie'|trans }}</a></li>
        <li><a href="{{ path('app_terreau_index') }}">{{ 'nav.terreau'|trans }}</a></li>
    </ul>
    <ul style="display: flex; gap: 0.5rem; align-items: center;">
        {% if app.user %}
            {% if is_granted('ROLE_ADMIN') %}
                <li><a href="{{ path('admin_dashboard') }}">🛡️ {{ 'nav.admin'|trans }}</a></li>
            {% endif %}
            <li><a href="{{ path('app_profile') }}">👤 {{ app.user.pseudo }}</a></li>
            <li><a href="{{ path('app_preferences') }}">⚙️ {{ 'nav.preferences'|trans }}</a></li>
            <li><a href="{{ path('app_logout') }}">{{ 'nav.logout'|trans }}</a></li>
        {% else %}
            <li><a href="{{ path('app_login') }}">{{ 'nav.login'|trans }}</a></li>
            <li><a href="{{ path('app_register') }}">{{ 'nav.register'|trans }}</a></li>
        {% endif %}
        <li>
            {# Language switcher #}
            {% set currentLocale = app.request.locale %}
            <form method="post" action="{{ path('app_preferences_language', {language: currentLocale == 'fr' ? 'en' : 'fr'}) }}" style="display:inline;">
                <button type="submit" style="background:none;border:1px solid rgba(255,255,255,0.3);color:rgba(255,255,255,0.9);padding:4px 10px;border-radius:6px;cursor:pointer;font-size:0.8rem;font-weight:600;">
                    {{ currentLocale == 'fr' ? '🇬🇧 EN' : '🇫🇷 FR' }}
                </button>
            </form>
        </li>
        <li>
            {{ include('components/theme_switcher.html.twig') }}
        </li>
    </ul>
</nav>
